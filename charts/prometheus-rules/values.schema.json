{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "prometheusDuration": {
      "type": "string",
      "pattern": "^(?:[0-9]+(?:ms|s|m|h|d|w|y))+$"
    },
    "prometheusExpr": {
      "type": "string",
      "minLength": 1
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "alert": {
          "type": "string",
          "minLength": 1,
          "default": "ExampleAlert"
        },
        "record": {
          "type": "string",
          "minLength": 1
        },
        "expr": {
          "$ref": "#/definitions/prometheusExpr",
          "default": "Vector(1)"
        },
        "for": {
          "$ref": "#/definitions/prometheusDuration",
          "default": "5m"
        },
        "keep_firing_for": {
          "$ref": "#/definitions/prometheusDuration"
        },
        "labels": {
          "allOf": [
            {
              "$ref": "#/definitions/stringMap"
            }
          ],
          "properties": {
            "severity": {
              "type": "string",
              "default": "warning",
              "description": "The severity label is mandatory for alerts (not records). We recommend either warning or critical"
            }
          }
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      },
      "required": [
        "expr"
      ],
      "oneOf": [
        {
          "required": [
            "alert"
          ]
        },
        {
          "required": [
            "record"
          ]
        }
      ]
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "default": "./example.rules"
        },
        "labels": {
          "$ref": "#/definitions/stringMap",
          "description": "Labels to add or overwrite before storing results for rules in this group. Rule-level labels take precedence."
        },
        "interval": {
          "$ref": "#/definitions/prometheusDuration"
        },
        "query_offset": {
          "$ref": "#/definitions/prometheusDuration",
          "description": "Offset the rule evaluation timestamp into the past for this group."
        },
        "partial_response_strategy": {
          "type": "string",
          "description": "Used by ThanosRuler and ignored by Prometheus instances."
        },
        "limit": {
          "type": "integer",
          "minimum": 0
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/rule"
          },
          "minItems": 1
        }
      },
      "required": [
        "name",
        "rules"
      ]
    }
  },
  "properties": {
    "defaultAlertLabels": {
      "$ref": "#/definitions/stringMap",
      "default": {}
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/group"
          },
          "minItems": 1
        }
      },
      "required": [
        "groups"
      ]
    }
  },
  "required": [
    "spec"
  ],
  "type": "object"
}
