        "initialDelaySeconds": {"minimum": 0, "type": "integer"},
        "periodSeconds": {"minimum": 1, "type": "integer"},
        "timeoutSeconds": {"minimum": 1, "type": "integer"},
        "failureThreshold": {"minimum": 1, "type": "integer"},
        "successThreshold": {"minimum": 1, "type": "integer"},
        "terminationGracePeriodSeconds": {"minimum": 0, "type": "integer"}
      },
      "type": "object"
    }
