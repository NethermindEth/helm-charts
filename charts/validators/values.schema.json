        "matchFields": {"items": {"$ref": "#/definitions/nodeSelectorRequirement"}, "type": "array"}
      },
      "type": "object"
    },
    "affinity": {
      "additionalProperties": false,
      "description": "ref: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.32/#affinity-v1-core",
      "properties": {
