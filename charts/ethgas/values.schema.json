  "additionalProperties": false,
  "definitions": {
    "resourceQuantity": {
      "description": "Kubernetes resource quantity (e.g. 100m, 256Mi, 1Gi)",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ]
    },
    "resourceList": {
      "additionalProperties": false,
      "patternProperties": {
        "^hugepages-.*$": {
          "$ref": "#/definitions/resourceQuantity"
        }
      },
      "properties": {
        "cpu": {
          "$ref": "#/definitions/resourceQuantity"
        },
        "memory": {
          "$ref": "#/definitions/resourceQuantity"
        },
        "ephemeral-storage": {
          "$ref": "#/definitions/resourceQuantity"
        }
      },
      "type": "object"
    },
    "resourceRequirements": {
      "additionalProperties": false,
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      },
      "type": "object"
    },
    "portOrName": {
      "oneOf": [
        {
          "minimum": 1,
          "maximum": 65535,
          "type": "integer"
        },
        {
          "minLength": 1,
          "type": "string"
        }
      ]
    },
    "httpGetAction": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "port": {
          "$ref": "#/definitions/portOrName"
