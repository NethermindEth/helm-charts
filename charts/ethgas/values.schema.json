        "httpHeaders": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": ["name", "value"],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": ["path", "port"],
      "type": "object"
    },
    "probe": {
      "additionalProperties": false,
      "properties": {
        "httpGet": {
          "allOf": [
            {
              "$ref": "#/definitions/httpGetAction"
            }
          ],
          "properties": {
            "path": {
              "default": "/"
            },
            "port": {
              "default": "http"
            }
          }
        },
        "initialDelaySeconds": {
          "minimum": 0,
          "type": "integer"
        },
        "periodSeconds": {
          "minimum": 1,
          "type": "integer"
        },
        "timeoutSeconds": {
          "minimum": 1,
          "type": "integer"
        },
        "successThreshold": {
          "minimum": 1,
          "type": "integer"
        },
        "failureThreshold": {
          "minimum": 1,
          "type": "integer"
        },
        "terminationGracePeriodSeconds": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": ["httpGet"],
      "type": "object"
    },
    "kubernetesQualifiedName": {
      "description": "Kubernetes qualified name used for label/annotation keys.",
      "maxLength": 317,
      "pattern": "^(([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?[A-Za-z0-9]([A-Za-z0-9_.-]{0,61}[A-Za-z0-9])?)$",
      "type": "string"
    },
    "kubernetesLabelValue": {
      "description": "Kubernetes label value (empty string or up to 63 chars, alphanumeric boundaries).",
      "pattern": "^(([A-Za-z0-9][-A-Za-z0-9_.]{0,61}[A-Za-z0-9])?)$",
      "type": "string"
    },
    "kubernetesAnnotations": {
      "additionalProperties": {
